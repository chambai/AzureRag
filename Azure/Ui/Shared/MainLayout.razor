@inherits LayoutComponentBase
@using Ui.Themes
appsettings.Development.json

<MudThemeProvider Theme="ChatAiTheme.Theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <MudAppBar Color="Color.Primary" Elevation="1">
        <MudText Typo="Typo.h6">RAG Document Assistant</MudText>
    </MudAppBar>

    <MudDrawer Open="true"
               Variant="DrawerVariant.Persistent"
               ClipMode="DrawerClipMode.Always"
               Elevation="1"
               Width="240px">

        <MudNavMenu>

            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Chat">
                Chat
            </MudNavLink>

            <MudNavLink Href="/upload" Icon="@Icons.Material.Filled.Upload">
                Upload
            </MudNavLink>

            <MudNavLink Href="/documents" Icon="@Icons.Material.Filled.Description">
                Documents
            </MudNavLink>

        </MudNavMenu>

    </MudDrawer>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>

</MudLayout>
