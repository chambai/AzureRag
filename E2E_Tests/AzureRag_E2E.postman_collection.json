    {
      "name": "Query",
      "item": [
        {
          "name": "Query about secondary employment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is not empty', function () {",
                  "    pm.expect(pm.response.text().length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Response mentions employment', function () {",
                  "    var body = pm.response.text().toLowerCase();",
                  "    pm.expect(body).to.match(/employ|secondary|inform|manager/);",
                  "});",
                  "",
                  "pm.test('Response time is under 30s', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(30000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{AZUREFUNCTION}}/api/query?q=Am I allowed secondary employment",
              "host": ["{{AZUREFUNCTION}}"],
              "path": ["api", "query"],
              "query": [
                {
                  "key": "q",
                  "value": "Am I allowed secondary employment"
                }
              ]
            }
          },
          "response": []
        },
