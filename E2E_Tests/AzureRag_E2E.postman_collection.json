  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Wait for AzureFunction to be ready",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('AzureFunction is reachable', function () {",
                  "    pm.expect(pm.response.code).to.be.below(500);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{AZUREFUNCTION}}/api/query?q=ping",
              "host": ["{{AZUREFUNCTION}}"],
              "path": ["api", "query"],
              "query": [
                {
                  "key": "q",
                  "value": "ping"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload document successfully",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response confirms upload', function () {",
                  "    var body = pm.response.text();",
                  "    pm.expect(body).to.include('test_upload.txt');",
                  "    pm.expect(body).to.include('uploaded');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Filename",
                "value": "test_upload.txt",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "E2E_Tests/files/test_upload.txt"
                }
              ]
            },
            "url": {
              "raw": "{{AZUREFUNCTION}}/api/upload",
              "host": ["{{AZUREFUNCTION}}"],
              "path": ["api", "upload"]
            }
          },
          "response": []
        },
        {
          "name": "Upload fails without X-Filename header",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error mentions missing header', function () {",
                  "    var body = pm.response.text();",
                  "    pm.expect(body).to.include('X-Filename');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "E2E_Tests/files/test_upload.txt"
                }
              ]
            },
            "url": {
              "raw": "{{AZUREFUNCTION}}/api/upload",
              "host": ["{{AZUREFUNCTION}}"],
              "path": ["api", "upload"]
            }
          },
          "response": []
        },
        {
          "name": "Upload fails without file body",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Filename",
                "value": "empty.txt",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{AZUREFUNCTION}}/api/upload",
              "host": ["{{AZUREFUNCTION}}"],
              "path": ["api", "upload"]
            }
          },
          "response": []
        }
      ]
